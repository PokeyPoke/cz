      "segments": [
        {
          "type": "dialogue",
          "audioSrc": "/cz/audio/01-greetings/lesson-02/dialogue",
          "title": "Saying Goodbye",
          "context": "After the conference, you're leaving.",
          "lines": [
            { "speaker": "A", "czech": "Už musím jít.", "english": "I have to go now.", "startTime": 0, "endTime": 2 },
            { "speaker": "B", "czech": "Škoda. Na shledanou.", "english": "That's a pity. Goodbye.", "startTime": 2, "endTime": 5 },
            { "speaker": "A", "czech": "Na shledanou. Mějte se hezky.", "english": "Goodbye. Take care.", "startTime": 5, "endTime": 8.5 },
            { "speaker": "B", "czech": "Děkuji, vy také.", "english": "Thank you, you too.", "startTime": 8.5, "endTime": 11 },
            { "speaker": "A", "czech": "Promiňte, kde je východ?", "english": "Excuse me, where is the exit?", "startTime": 11, "endTime": 14.5 },
            { "speaker": "B", "czech": "Tamhle vpravo.", "english": "Over there on the right.", "startTime": 14.5, "endTime": 16.5 },
            { "speaker": "A", "czech": "Děkuji. Nashle.", "english": "Thank you. Bye.", "startTime": 16.5, "endTime": 18.5 }
          ]
        },
        {
          "type": "phrases",
          "title": "Key Phrases",
          "phrases": [
            { "id": "ph-1", "czech": "Na shledanou", "english": "Goodbye (formal)", "transliteration": "nah SKHLEH-dah-noh", "audioSrc": "/cz/audio/01-greetings/lesson-02/ph-01" },
            { "id": "ph-2", "czech": "Nashle", "english": "Bye (informal)", "transliteration": "NAH-skhleh", "notes": "Short for Na shledanou", "audioSrc": "/cz/audio/01-greetings/lesson-02/ph-02" },
            { "id": "ph-3", "czech": "Mějte se hezky", "english": "Take care / Have a nice day", "transliteration": "MYEY-teh seh HEZ-kee", "audioSrc": "/cz/audio/01-greetings/lesson-02/ph-03" },
            { "id": "ph-4", "czech": "Promiňte", "english": "Excuse me / Sorry (formal)", "transliteration": "PROH-min-yteh", "audioSrc": "/cz/audio/01-greetings/lesson-02/ph-04" },
            { "id": "ph-5", "czech": "Prosím", "english": "Please / You're welcome / Here you go", "transliteration": "PROH-seem", "notes": "The Swiss army knife of Czech politeness!", "audioSrc": "/cz/audio/01-greetings/lesson-02/ph-05" },
            { "id": "ph-6", "czech": "Ano / Ne", "english": "Yes / No", "transliteration": "AH-noh / neh", "audioSrc": "/cz/audio/01-greetings/lesson-02/ph-06" }
          ]
