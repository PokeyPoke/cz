          "title": "Meeting Someone New",
          "context": "You're at a conference in Prague. Someone approaches you.",
          "lines": [
            { "speaker": "A", "czech": "Dobrý den.", "english": "Good day.", "startTime": 0, "endTime": 1.5 },
            { "speaker": "B", "czech": "Dobrý den. Jak se máte?", "english": "Good day. How are you?", "startTime": 1.5, "endTime": 4 },
            { "speaker": "A", "czech": "Děkuji, dobře. A vy?", "english": "Thank you, well. And you?", "startTime": 4, "endTime": 7 },
            { "speaker": "B", "czech": "Také dobře, děkuji.", "english": "Also well, thank you.", "startTime": 7, "endTime": 9.5 },
            { "speaker": "A", "czech": "Jmenuji se Petr. A vy?", "english": "My name is Petr. And you?", "startTime": 9.5, "endTime": 13 },
            { "speaker": "B", "czech": "Jmenuji se Eva. Těší mě.", "english": "My name is Eva. Pleased to meet you.", "startTime": 13, "endTime": 17 },
            { "speaker": "A", "czech": "Těší mě. Odkud jste?", "english": "Pleased to meet you. Where are you from?", "startTime": 17, "endTime": 20 },
            { "speaker": "B", "czech": "Jsem z Ameriky. A vy?", "english": "I'm from America. And you?", "startTime": 20, "endTime": 23.5 },
            { "speaker": "A", "czech": "Jsem z Anglie.", "english": "I'm from England.", "startTime": 23.5, "endTime": 25.5 }
          ]
        },
        {
