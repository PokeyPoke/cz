            { "id": "ph-2", "czech": "Jak se máte?", "english": "How are you? (formal)", "transliteration": "yahk seh MAH-teh", "audioSrc": "/cz/audio/01-greetings/lesson-01/ph-02" },
            { "id": "ph-3", "czech": "Děkuji, dobře", "english": "Thank you, well / I'm fine", "transliteration": "DYEH-koo-yee DOB-rzheh", "notes": "Děkuji = thank you. Short form: Díky (informal)", "audioSrc": "/cz/audio/01-greetings/lesson-01/ph-03" },
            { "id": "ph-4", "czech": "A vy?", "english": "And you? (formal)", "audioSrc": "/cz/audio/01-greetings/lesson-01/ph-04" },
            { "id": "ph-5", "czech": "Jmenuji se...", "english": "My name is...", "transliteration": "YMEH-noo-yee seh", "notes": "Literally: I call myself...", "audioSrc": "/cz/audio/01-greetings/lesson-01/ph-05" },
            { "id": "ph-6", "czech": "Těší mě", "english": "Pleased to meet you", "transliteration": "TYEH-shee myeh", "notes": "Literally: It pleases me", "audioSrc": "/cz/audio/01-greetings/lesson-01/ph-06" },
            { "id": "ph-7", "czech": "Odkud jste?", "english": "Where are you from? (formal)", "transliteration": "OD-kood steh", "audioSrc": "/cz/audio/01-greetings/lesson-01/ph-07" },
